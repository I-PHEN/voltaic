# Voltaic LLM planner configuration — copy to .env and fill in your key.
# The .env file is gitignored; this example file is safe to commit.

# Your provider API key (Groq: https://console.groq.com/keys)
GROQ_API_KEY=

# OpenAI-compatible endpoint + model. Defaults target Groq.
# To swap providers later, change these three lines only:
#   Groq:       https://api.groq.com/openai/v1        openai/gpt-oss-120b
#   OpenRouter: https://openrouter.ai/api/v1          anthropic/claude-3.5-sonnet
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=openai/gpt-oss-120b
